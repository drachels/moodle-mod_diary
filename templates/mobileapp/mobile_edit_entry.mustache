{{!
    @template mod_diary/mobileapp/mobile_edit_entry

    Mobile edit entry view for the Diary plugin.

    Example context (json):
    {
        "cmid": 12,
        "name": "Diary",
        "canedit": true,
        "diaryid": 34,
        "format": 1,
        "text_plain": "My current entry"
    }
}}

<div class="ion-padding">
    {{#warning}}
        <core-alert message="{{warning}}" type="warning"></core-alert>
    {{/warning}}

    <ion-card>
        <ion-card-header>
            <ion-card-title>{{name}}</ion-card-title>
        </ion-card-header>
        <ion-card-content>
            <h3 style="margin-top: 0;">{{#str}}startoredit, mod_diary{{/str}}</h3>
            {{#info}}<p><i>{{info}}</i></p>{{/info}}

            {{#hasmobilecontext}}
                {{#promptmode_summary}}<p><strong>{{promptmode_summary}}</strong></p>{{/promptmode_summary}}
                {{#promptcount_total}}<p>{{{promptcount_total}}}</p>{{/promptcount_total}}
                {{#promptcount_breakdown}}<p>{{{promptcount_breakdown}}}</p>{{/promptcount_breakdown}}

                {{#haspromptsummary}}
                    <div style="margin: 10px 0 15px;">
                        <h3 style="margin: 0 0 6px;">{{prompttitle}}</h3>
                        {{#promptdates}}<p><i>{{promptdates}}</i></p>{{/promptdates}}
                        <core-format-text text="{{promptbody}}" component="mod_diary" component-id="{{cmid}}"></core-format-text>
                    </div>
                {{/haspromptsummary}}

                {{#haslimitnotes}}
                    <div style="margin-bottom: 15px;">
                        {{#limitnotes}}<p>{{{html}}}</p>{{/limitnotes}}
                    </div>
                {{/haslimitnotes}}

                {{#hasmetricrequirements}}
                    <div style="margin-bottom: 15px;">
                        <h3 style="margin: 0 0 6px;">{{metricrequirementstitle}}</h3>
                        <ion-list>
                            {{#metricrequirements}}
                                <ion-item lines="none">
                                    <ion-label>{{text}}</ion-label>
                                </ion-item>
                            {{/metricrequirements}}
                        </ion-list>
                    </div>
                {{/hasmetricrequirements}}
            {{/hasmobilecontext}}

            {{^canedit}}
                <core-alert message="{{#str}}editingended, mod_diary{{/str}}" type="info"></core-alert>
            {{/canedit}}

            {{#canedit}}
                <!-- 
                    FORM CONTAINER
                    Using <form ngNoForm> creates a standard HTML form context.
                    This allows the directive to find the textarea easily.
                -->
                <form id="diary-entry-form-{{cmid}}" ngNoForm>
                    {{#haspromptselector}}
                        <div style="margin-bottom: 15px;">
                            <label style="display: block; color: #666; font-size: 12px; margin-bottom: 5px;">
                                {{promptselectorlabel}}
                            </label>
                            <select name="promptid"
                                    style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px; background: white; -webkit-appearance: none;">
                                {{#promptoptions}}
                                    <option value="{{value}}" {{selected}}>{{label}}</option>
                                {{/promptoptions}}
                            </select>
                        </div>
                    {{/haspromptselector}}
                    
                    <!-- Textarea wrapped in a plain div -->
                    <div style="margin-bottom: 15px;">
                    <textarea
                        name="text"
                        rows="15"
                            style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; font-family: sans-serif; background: #fff; color: #111;"
                        placeholder="{{#str}}entry, mod_diary{{/str}}">{{text_plain}}</textarea>
                    </div>

                    <input type="hidden" name="cmid" value="{{cmid}}">
                    <input type="hidden" name="entryid" value="{{entryid}}">
                    {{^haspromptselector}}<input type="hidden" name="promptid" value="{{promptid}}">{{/haspromptselector}}
                    <input type="hidden" name="format" value="{{format}}">
                    <input type="hidden" name="itemid" value="0">
                </form>

                <div class="ion-margin-top">
                   

                    <!-- 
                        SAVE BUTTON
                        1. core-site-plugins-call-ws on the ion-button.
                        2. form="diary-entry-form-{{cmid}}" links to the form ID above.
                        3. goBackOnSuccess="true" automatically navigates back to the View page on success.
                    -->
                    <ion-button
                        expand="block"
                        core-site-plugins-call-ws
                        name="mod_diary_set_text"
                        form="diary-entry-form-{{cmid}}"
                        successMessage="{{#str}}changessaved, mod_diary{{/str}}"
                        (onSuccess)="onDiaryEntrySaved($event)"
                        goBackOnSuccess="true">
                        {{#str}}savechanges{{/str}}
                    </ion-button>

                    <ion-button
                        expand="block"
                        fill="outline"
                        core-site-plugins-call-ws
                        name="mod_diary_set_text"
                        form="diary-entry-form-{{cmid}}"
                        successMessage="{{#str}}changessaved, mod_diary{{/str}}"
                        (onSuccess)="onDiaryEntrySaved($event)">
                        {{#str}}saveandcontinueediting, mod_diary{{/str}}
                    </ion-button>

                    <ion-button expand="block" fill="clear" onclick="history.back();">
                        {{#str}}cancel{{/str}}
                    </ion-button>
                </div>
            {{/canedit}}

            {{^canedit}}
                <div class="ion-margin-top">
                    <ion-button expand="block" fill="clear" onclick="history.back();">
                        {{#str}}back{{/str}}
                    </ion-button>
                </div>
            {{/canedit}}
        </ion-card-content>
    </ion-card>
</div>